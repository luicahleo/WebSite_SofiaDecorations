<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Acción para abrir el listado -->
        <record id="action_hola_mundo" model="ir.actions.act_window">
            <field name="name">Hola Mundo</field>
            <field name="res_model">sofia.hola.mundo</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    ¡Crea tu primer registro de Hola Mundo!
                </p>
            </field>
        </record>

        <!-- Vista de árbol (listado) -->
        <record id="view_hola_mundo_tree" model="ir.ui.view">
            <field name="name">sofia.hola.mundo.tree</field>
            <field name="model">sofia.hola.mundo</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="mensaje"/>
                    <field name="activo"/>
                    <field name="fecha_creacion"/>
                </tree>
            </field>
        </record>

        <!-- Vista de formulario (detalle) -->
        <record id="view_hola_mundo_form" model="ir.ui.view">
            <field name="name">sofia.hola.mundo.form</field>
            <field name="model">sofia.hola.mundo</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1>
                            <field name="name" placeholder="Ingresa un nombre"/>
                        </h1>
                        <group>
                            <field name="mensaje"/>
                            <field name="activo"/>
                            <field name="fecha_creacion"/>
                        </group>
                        <footer>
                            <button name="action_saludo" type="object" 
                                    string="🎉 Saludar" class="btn-primary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Menú para acceder -->
        <menuitem 
            id="menu_hola_mundo" 
            name="Hola Mundo"
            parent="sofia_base.menu_sofia_decorations_root"
            action="action_hola_mundo"
            sequence="1"/>
    </data>
</odoo>
